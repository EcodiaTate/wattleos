# KeyPay / Employment Hero Integration
# ============================================================
# Copy these to .env.local or your deployment environment

# OAuth credentials from KeyPay developer portal
# https://developer.yourpayroll.io/
KEYPAY_CLIENT_ID=your_client_id_here
KEYPAY_CLIENT_SECRET=your_client_secret_here
KEYPAY_REDIRECT_URI=https://your-domain.com/api/oauth/keypay/callback

# Field encryption key (for storing OAuth tokens securely)
# Generate with: openssl rand -hex 32
# This must match FIELD_ENCRYPTION_KEY if already set for other purposes
FIELD_ENCRYPTION_KEY=your_64_hex_char_key_here
