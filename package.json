{
  "name": "wattleos-v2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "security:test": "npx tsx scripts/security-test.ts",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "db:seed": "supabase db seed",
    "db:types": "supabase gen types typescript --local > src/types/database.ts",
    "cap:sync": "npx cap sync",
    "cap:sync:ios": "npx cap sync ios",
    "cap:sync:android": "npx cap sync android",
    "cap:ios": "npx cap open ios",
    "cap:android": "npx cap open android",
    "cap:build:ios": "npx cap sync ios && npx cap open ios",
    "cap:build:android": "npx cap sync android && npx cap open android",
    "cap:dev:ios": "CAPACITOR_SERVER_URL=http://192.168.1.X:3001 npx cap sync ios && npx cap open ios",
    "cap:dev:android": "CAPACITOR_SERVER_URL=http://192.168.1.X:3001 npx cap sync android && npx cap open android",
    "postinstall": "node scripts/patch-next-devtools.mjs"
  },
  "dependencies": {
    "@capacitor/action-sheet": "^8.0.1",
    "@capacitor/android": "^8.1.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/browser": "^8.0.1",
    "@capacitor/camera": "^8.0.1",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/clipboard": "^8.0.1",
    "@capacitor/core": "^8.1.0",
    "@capacitor/device": "^8.0.1",
    "@capacitor/geolocation": "^8.1.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/local-notifications": "^8.0.1",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.1",
    "@capacitor/screen-orientation": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@capawesome/capacitor-badge": "^8.0.1",
    "@react-pdf/renderer": "^4.3.2",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.10",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/qrcode": "^1.5.6",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.2",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.575.0",
    "next": "^16.1.6",
    "openai": "^6.22.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^6.9.2",
    "stripe": "^20.3.1",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cookie": "^0.6.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "typescript": "^5"
  }
}
