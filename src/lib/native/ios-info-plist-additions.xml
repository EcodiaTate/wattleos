<!-- ios/App/App/Info.plist — ADDITIONS -->
<!--
  ============================================================
  WattleOS - iOS Permission Strings
  ============================================================
  Add these keys to the existing Info.plist generated by
  `npx cap add ios`. Each string is shown to the user when
  the app requests the corresponding permission.

  WHY each permission matters for WattleOS is noted inline.
  ============================================================
-->

<!-- CAMERA — Observation photo/video capture -->
<!-- WHY: Guides photograph student work for observation records -->
<key>NSCameraUsageDescription</key>
<string>WattleOS uses your camera to capture observation photos and videos of student learning activities.</string>

<!-- PHOTO LIBRARY — Gallery access for observation media -->
<!-- WHY: Guides may select existing photos from their camera roll -->
<key>NSPhotoLibraryUsageDescription</key>
<string>WattleOS needs access to your photos to attach existing images to observations.</string>

<!-- PHOTO LIBRARY ADD — Save captured photos -->
<key>NSPhotoLibraryAddUsageDescription</key>
<string>WattleOS can save observation photos to your camera roll.</string>

<!-- PUSH NOTIFICATIONS — Real-time alerts -->
<!-- WHY: Absence alerts, parent messages, emergency notifications -->
<key>UIBackgroundModes</key>
<array>
  <string>remote-notification</string>
</array>

<!-- LOCATION — Excursion tracking -->
<!-- WHY: Track group location during off-campus excursions for safety -->
<key>NSLocationWhenInUseUsageDescription</key>
<string>WattleOS uses your location during excursions to track group position for student safety.</string>

<!-- FACE ID — Biometric authentication (future) -->
<key>NSFaceIDUsageDescription</key>
<string>WattleOS uses Face ID for quick, secure login.</string>

<!-- MICROPHONE — Video observations with audio -->
<key>NSMicrophoneUsageDescription</key>
<string>WattleOS uses the microphone to record audio with observation videos.</string>

<!--
  ============================================================
  App Transport Security — Allow WattleOS domains
  ============================================================
  Since we use server.url to load from wattleos.au, ensure
  ATS allows our domains. HTTPS is enforced by default.
-->
<key>NSAppTransportSecurity</key>
<dict>
  <key>NSAllowsArbitraryLoadsInWebContent</key>
  <true/>
</dict>

<!--
  ============================================================
  Universal Links — Deep link handling
  ============================================================
  Add to Entitlements: com.apple.developer.associated-domains
  Value: applinks:app.wattleos.au, applinks:*.wattleos.au

  Also create .well-known/apple-app-site-association on wattleos.au
-->

<!--
  ============================================================
  iPad Multitasking Support
  ============================================================
  Enable Split View and Slide Over for iPad productivity.
-->
<key>UIRequiresFullScreen</key>
<false/>
<key>UISupportedInterfaceOrientations~ipad</key>
<array>
  <string>UIInterfaceOrientationPortrait</string>
  <string>UIInterfaceOrientationPortraitUpsideDown</string>
  <string>UIInterfaceOrientationLandscapeLeft</string>
  <string>UIInterfaceOrientationLandscapeRight</string>
</array>
<key>UISupportedInterfaceOrientations</key>
<array>
  <string>UIInterfaceOrientationPortrait</string>
</array>
